NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional newer Supabase public key name. Either this or NEXT_PUBLIC_SUPABASE_ANON_KEY works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Required for Phase 3E password-protected galleries (server-side reads of
# private gallery photos after the access cookie is verified).
# Get from Supabase dashboard → Project Settings → API → service_role key.
# NEVER expose this to the browser. Server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 — required for photo uploads (Phase 3B).
# Originals are stored privately and served via short-lived signed URLs.
# See README for step-by-step setup.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional. Set only if you front the bucket with a public custom domain.
# When unset, all reads go through signed S3 URLs (recommended for now).
R2_PUBLIC_BASE_URL=
# Optional. Defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Required for Phase 3E password-protected galleries.
# Used to HMAC-sign the per-gallery access cookie. Must be ≥ 32 chars.
# Generate with: openssl rand -hex 32
GALLERY_ACCESS_SECRET=

# Optional — Phase 3H-mini: email notification when a client submits selects.
# All three must be set together; if any is missing, submissions still succeed
# but no email is sent. See README for setup.
# RESEND_API_KEY: from https://resend.com/api-keys
# SELECTS_NOTIFICATION_TO: photographer's inbox
# SELECTS_NOTIFICATION_FROM: must be a verified Resend sender. For testing,
#   "Nhihad Hassan Photography <onboarding@resend.dev>" works without domain
#   verification.
RESEND_API_KEY=
SELECTS_NOTIFICATION_TO=
SELECTS_NOTIFICATION_FROM=
