NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional newer Supabase public key name. Either this or NEXT_PUBLIC_SUPABASE_ANON_KEY works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Required for Phase 3E password-protected galleries (server-side reads of
# private gallery photos after the access cookie is verified).
# Get from Supabase dashboard → Project Settings → API → service_role key.
# NEVER expose this to the browser. Server-only.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 — required for photo uploads (Phase 3B).
# Originals are stored privately and served via short-lived signed URLs.
# See README for step-by-step setup.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional. Set only if you front the bucket with a public custom domain.
# When unset, all reads go through signed S3 URLs (recommended for now).
R2_PUBLIC_BASE_URL=
# Optional. Defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Required for Phase 3E password-protected galleries.
# Used to HMAC-sign the per-gallery access cookie. Must be ≥ 32 chars.
# Generate with: openssl rand -hex 32
GALLERY_ACCESS_SECRET=

# Optional — Phase 3H-mini: email notification when a client submits selects.
# All three must be set together; if any is missing, submissions still succeed
# but no email is sent. See README for setup.
# RESEND_API_KEY: from https://resend.com/api-keys
# SELECTS_NOTIFICATION_TO: photographer's inbox
# SELECTS_NOTIFICATION_FROM: must be a verified Resend sender. For testing,
#   "Nhihad Hassan Photography <onboarding@resend.dev>" works without domain
#   verification.
RESEND_API_KEY=
SELECTS_NOTIFICATION_TO=
SELECTS_NOTIFICATION_FROM=

# Optional — read-only availability calendar on /contact.
# Set to the SECRET iCal URL of a dedicated Google Calendar that holds your
# confirmed shoots (do NOT use your personal calendar — every dentist
# appointment will show as "Held").
#
# Setup:
#   1. Google Calendar → create a new calendar, e.g. "NHP Bookings".
#   2. Open that calendar's settings → "Settings for my calendars".
#   3. Scroll to "Integrate calendar" → copy "Secret address in iCal format".
#   4. Paste below. Treat this URL as a password — anyone with it can read
#      every event title, time, and description.
#
# Behaviour: when unset, the calendar section on /contact does not render.
# When set, the server fetches the feed every 10 minutes, exposes only
# per-day status (open / tentative / held), and the URL never reaches
# the browser.
#
# Marking events:
#   * Confirmed booking → regular event title (e.g. "Smith wedding")
#   * Tentative hold     → prefix the title with [T] or [TENTATIVE]
#                          (e.g. "[T] Maybe Smith wedding")
#   * Day vs night       → an event before 5 PM Toronto = day slot only;
#                          at/after 5 PM = night slot only; spanning the
#                          boundary or all-day = full day.
# The title prefix is stripped server-side; clients never see event titles.
GOOGLE_CALENDAR_ICAL_URL=
